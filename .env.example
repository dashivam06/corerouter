# =================================================================
# COREROUTER SYSTEM ENVIRONMENT TEMPLATE
# =================================================================

# Server Configuration
SERVER_PORT=7777

# Database Configuration (PostgreSQL)
DB_HOST=your-db-host.postgres.database.azure.com
DB_PORT=5432
DB_NAME=corerouter
DB_USERNAME=your_db_user
DB_PASSWORD=your_secure_password

# Redis Configuration (Cache & Task Streams)
REDIS_HOST=your-redis-host.cloud.redislabs.com
REDIS_PORT=16383
REDIS_PASSWORD=your_redis_password

# Security & Encryption
# Use a strong 64+ character string for JWT_SECRET
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000
ENCRYPTION_KEY=your_base64_encryption_key_for_api_keys
SECURITY_APIKEY_PEPPER=your_random_pepper_string

# Azure Observability (Application Insights)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=your-url
INSTRUMENTATION_KEY=your-guid-here
AZURE_APPINSIGHTS_APP_ID=your-app-id

# AI Provider Configuration
VLLM_HOST=https://your-ai-worker-host.com

# Azure Entra ID (OAuth2 & Identity)
AZURE_ENTRA_TENANT_ID=your-tenant-id
AZURE_ENTRA_CLIENT_ID=your-client-id
AZURE_ENTRA_CLIENT_SECRET=your-client-secret

# Social Auth: GitHub
GUTHIB_CLIENT_ID=your_github_id
GUTHIB_CLIENT_SECRET=your_github_secret

# Social Auth: Google
GOOGLE_CLIENT_ID=your_google_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_secret
